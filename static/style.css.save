* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

body.light {
    background-color: #f5f5f5;
    color: #333;
}

body.dark {
    background-color: #1a1a1a;
    color: #f5f5f5;
}

nav {
    background: #5a2d8c;
    color: white;
    padding: 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
}

.nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    position: relative;
}

.logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: white;
    text-decoration: none;
}

.nav-links-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-left: 2rem;
}

.nav-links-left a {
    color: white;
    text-decoration: none;
    transition: opacity 0.3s ease;
}

.nav-links-left a:hover {
    opacity: 0.8;
}

.user-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.15);
    padding: 0.5rem 1rem;
    border-radius: 50px;
}

.user-info .username {
    font-weight: bold;
    font-size: 0.9rem;
}

.user-info .user-role {
    background: rgba(255, 255, 255, 0.25);
    padding: 0.25rem 0.6rem;
    border-radius: 50px;
    font-size: 0.75rem;
    text-transform: capitalize;
}

.burger-menu {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 101;
}

.burger-menu span {
    display: block;
    width: 25px;
    height: 3px;
    background: white;
    margin: 5px 0;
    transition: all 0.3s ease;
    border-radius: 3px;
}

.sidebar-menu {
    position: fixed;
    top: 0;
    left: -280px;
    width: 280px;
    height: 100%;
    background: #5a2d8c;
    z-index: 1000;
    transition: left 0.3s ease;
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.3);
    overflow-y: auto;
}

.sidebar-menu.open {
    left: 0;
}

.sidebar-header {
    padding: 2rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    margin-bottom: 1rem;
}

.sidebar-user-info {
    text-align: center;
}

.sidebar-username {
    display: block;
    font-size: 1.25rem;
    font-weight: bold;
    color: white;
    margin-bottom: 0.5rem;
}

.sidebar-user-role {
    display: inline-block;
    background: rgba(255, 255, 255, 0.25);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.75rem;
    color: white;
    text-transform: capitalize;
}

.sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.sidebar-links a {
    color: white;
    text-decoration: none;
    padding: 1rem 1.5rem;
    transition: background 0.3s ease;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.sidebar-links a:hover {
    background: rgba(255, 255, 255, 0.1);
}

.sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
    display: none;
}

.sidebar-overlay.active {
    display: block;
}

main {
    flex: 1;
    max-width: 1200px;
    margin: 2rem auto;
    padding: 0 1rem;
    width: 100%;
}

.hero {
    text-align: center;
    padding: 3rem 1rem;
}

.hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
}

.features {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin: 3rem 0;
    flex-wrap: wrap;
}

.feature {
    background: rgba(90, 45, 140, 0.1);
    padding: 1.5rem;
    border-radius: 8px;
    max-width: 300px;
    flex: 1;
    min-width: 250px;
}

body.dark .feature {
    background: rgba(90, 45, 140, 0.3);
}

.btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    margin: 0.5rem;
    text-decoration: none;
    border-radius: 5px;
    font-weight: bold;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.3s ease;
}

.btn-primary {
    background: #5a2d8c;
    color: white;
}

.btn-primary:hover {
    background: #6b3e9c;
    transform: translateY(-2px);
}

.btn-secondary {
    background: transparent;
    color: #5a2d8c;
    border: 2px solid #5a2d8c;
}

body.dark .btn-secondary {
    color: #9b6bc1;
    border-color: #9b6bc1;
}

.btn-success {
    background: #00c851;
    color: white;
}

.btn-success:hover {
    background: #00a844;
}

.btn-danger {
    background: #ff4444;
    color: white;
}

.btn-danger:hover {
    background: #cc0000;
}

.btn-small {
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    margin: 0;
}

.form-container {
    max-width: 500px;
    margin: 0 auto;
    padding: 2rem;
    background: rgba(90, 45, 140, 0.05);
    border-radius: 8px;
}

body.dark .form-container {
    background: rgba(90, 45, 140, 0.15);
}

.form-group {
    margin-bottom: 1rem;
}

.form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: bold;
}

.form-group input, 
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: #5a2d8c;
}

body.dark .form-group input,
body.dark .form-group select,
body.dark .form-group textarea {
    background: #333;
    border-color: #555;
    color: white;
}

.form-group textarea {
    font-family: monospace;
    resize: vertical;
}

.form-group small {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: #666;
}

body.dark .form-group small {
    color: #aaa;
}

.error {
    background: #ff4444;
    color: white;
    padding: 0.75rem;
    border-radius: 5px;
    margin-bottom: 1rem;
}

.success {
    background: #00c851;
    color: white;
    padding: 0.75rem;
    border-radius: 5px;
    margin-bottom: 1rem;
}

.recovery-phrase {
    background: #333;
    color: #0f0;
    font-family: monospace;
    padding: 1rem;
    margin: 1rem 0;
    border-radius: 5px;
    word-break: break-all;
}

.dashboard-actions {
    display: flex;
    gap: 1rem;
    margin: 2rem 0;
    flex-wrap: wrap;
}

.profile-container {
    max-width: 800px;
    margin: 0 auto;
}

.account-info {
    background: rgba(90, 45, 140, 0.05);
    padding: 1rem;
    border-radius: 8px;
}

body.dark .account-info {
    background: rgba(90, 45, 140, 0.15);
}

.account-info p {
    margin: 0.5rem 0;
}

.settings-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid #ddd;
    border-radius: 8px;
}

body.dark .settings-section {
    border-color: #444;
}

.action-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid #eee;
}

body.dark .action-item {
    border-bottom-color: #444;
}

.action-item:last-child {
    border-bottom: none;
}

.action-info h3 {
    margin: 0 0 0.25rem 0;
    font-size: 1rem;
}

.action-info p {
    margin: 0;
    font-size: 0.875rem;
    color: #666;
}

body.dark .action-info p {
    color: #aaa;
}

.danger-item .action-info h3 {
    color: #ff4444;
}

.theme-switch {
    position: relative;
    display: inline-block;
    width: 60px;
    height: 34px;
}

.theme-switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.theme-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #ccc;
    transition: 0.4s;
    border-radius: 34px;
}

.theme-slider:before {
    position: absolute;
    content: "";
    height: 26px;
    width: 26px;
    left: 4px;
    bottom: 4px;
    background-color: white;
    transition: 0.4s;
    border-radius: 50%;
}

input:checked + .theme-slider {
    background-color: #5a2d8c;
}

input:checked + .theme-slider:before {
    transform: translateX(26px);
}

.form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
}

.return-link {
    text-align: center;
    margin-top: 1.5rem;
}

.warning-text {
    color: #ff4444;
    font-weight: bold;
    margin-bottom: 1rem;
    padding: 0.75rem;
    background: rgba(255, 68, 68, 0.1);
    border-radius: 5px;
}

.danger-container {
    border: 1px solid #ff4444;
}

body.dark .danger-container {
    border-color: #ff4444;
}

.history-container {
    max-width: 1200px;
    margin: 0 auto;
}

.table-responsive {
    overflow-x: auto;
    margin: 1rem 0;
}

.data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
}

.data-table th,
.data-table td {
    padding: 0.75rem;
    text-align: left;
    border-bottom: 1px solid #ddd;
}

body.dark .data-table th,
body.dark .data-table td {
    border-bottom-color: #444;
}

.data-table th {
    background: rgba(90, 45, 140, 0.1);
    font-weight: bold;
}

body.dark .data-table th {
    background: rgba(90, 45, 140, 0.3);
}

.data-table tr:hover {
    background: rgba(90, 45, 140, 0.05);
}

.status {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
}

.status-pending {
    background: #ffc107;
    color: #333;
}

.status-accepted {
    background: #00c851;
    color: white;
}

.status-declined {
    background: #ff4444;
    color: white;
}

.status-cancelled {
    background: #888;
    color: white;
}

.status-downloaded {
    background: #5a2d8c;
    color: white;
}

.action-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.no-action {
    color: #888;
}

.tabs {
    display: flex;
    gap: 0.5rem;
    margin: 1.5rem 0 1rem 0;
    border-bottom: 1px solid #ddd;
}

.tab-button {
    padding: 0.75rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
    color: #666;
    transition: all 0.3s ease;
}

.tab-button:hover {
    color: #5a2d8c;
}

.tab-button.active {
    color: #5a2d8c;
    border-bottom: 2px solid #5a2d8c;
}

body.dark .tab-button {
    color: #aaa;
}

body.dark .tab-button.active {
    color: #9b6bc1;
    border-bottom-color: #9b6bc1;
}

.tab-content {
    display: none;
}

.tab-content.active {
    display: block;
}

.file-item {
    background: rgba(90, 45, 140, 0.05);
    padding: 1rem;
    margin-bottom: 1rem;
    border-radius: 5px;
    border-left: 4px solid #5a2d8c;
}

body.dark .file-item {
    background: rgba(90, 45, 140, 0.15);
}

.file-actions {
    margin-top: 0.5rem;
}

.empty-message {
    color: #888;
    font-style: italic;
    padding: 1rem;
    text-align: center;
}

.progress-container {
    margin: 1rem 0;
    padding: 1rem;
    background: rgba(90, 45, 140, 0.1);
    border-radius: 5px;
}

.progress-bar {
    width: 0%;
    height: 20px;
    background: #5a2d8c;
    border-radius: 10px;
    animation: progress 0.5s ease-in-out infinite alternate;
}

@keyframes progress {
    from { width: 10%; }
    to { width: 90%; }
}

.progress-text {
    text-align: center;
    margin-top: 0.5rem;
}

.simple-nav {
    background: #5a2d8c;
    color: white;
    padding: 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
}

.simple-nav .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.simple-nav .logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: white;
    text-decoration: none;
}

.return-button-top {
    text-align: left;
    margin-bottom: 2rem;
}

.return-button-bottom {
    text-align: left;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #ddd;
}

body.dark .return-button-bottom {
    border-top-color: #444;
}

/* Footer Styles */
footer {
    background: #2d2d2d;
    color: #e0e0e0;
    padding: 2rem 1rem;
    margin-top: auto;
}

body.dark footer {
    background: #1a1a1a;
    color: #b0b0b0;
}

.footer-container {
    max-width: 1200px;
    margin: 0 auto;
}

.footer-content {
    text-align: center;
}

.footer-title {
    font-size: 1rem;
    font-weight: bold;
    margin-bottom: 0.75rem;
    color: #ffffff;
}

body.dark .footer-title {
    color: #e0e0e0;
}

.copyright {
    font-size: 0.875rem;
    margin: 0.5rem 0;
    color: #c0c0c0;
}

.version {
    font-size: 0.875rem;
    margin: 0.5rem 0;
    color: #c0c0c0;
}

.contact {
    font-size: 0.875rem;
    margin: 0.5rem 0;
    color: #c0c0c0;
    cursor: text;
    user-select: all;
}

.contact a {
    color: #9b6bc1;
    text-decoration: none;
    transition: color 0.3s ease;
}

.contact a:hover {
    color: #b88ad9;
    text-decoration: underline;
}

body.dark .contact a {
    color: #b88ad9;
}

body.dark .contact a:hover {
    color: #d4aaff;
}

/* Mobile Responsive */
@media (max-width: 768px) {
    .nav-container {
        flex-wrap: nowrap;
        justify-content: space-between;
    }
    
    .user-info {
        display: none;
    }
    
    .nav-links-left {
        display: none;
    }
    
    .burger-menu {
        display: block;
        order: 2;
    }
    
    .btn {
        display: block;
        width: 100%;
        text-align: center;
        margin: 0.5rem 0;
    }
    
    .dashboard-actions {
        flex-direction: column;
    }
    
    .form-container {
        padding: 1.5rem;
        margin: 1rem;
    }
    
    .feature {
        min-width: 100%;
    }
    
    .data-table th,
    .data-table td {
        padding: 0.5rem;
        font-size: 0.8rem;
    }
    
    .tab-button {
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
    }
    
    .action-buttons {
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .btn-small {
        text-align: center;
    }
    
    .action-item {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }
    
    .simple-nav .nav-container {
        flex-direction: row;
        justify-content: space-between;
    }
    
    .return-button-top,
    .return-button-bottom {
        text-align: center;
    }
    
    .return-button-top .btn,
    .return-button-bottom .btn {
        display: inline-block;
        width: auto;
    }
}

@media (max-width: 480px) {
    .hero h1 {
        font-size: 1.75rem;
    }
    
    .hero {
        padding: 2rem 1rem;
    }
}

/* 2FA Styles */
.qr-code {
    display: block;
    margin: 1rem auto;
    width: 200px;
    height: 200px;
    border: 1px solid #ddd;
    padding: 0.5rem;
    background: white;
    border-radius: 8px;
}

.secret-text {
    text-align: center;
    font-family: monospace;
    font-size: 0.9rem;
    margin: 1rem 0;
    word-break: break-all;
}

.codes-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    margin: 1rem 0;
}

.recovery-code {
    background: #f0f0f0;
    color: #333;
    padding: 0.5rem;
    text-align: center;
    font-family: monospace;
    font-size: 1rem;
    font-weight: bold;
    border-radius: 4px;
    letter-spacing: 1px;
}

body.dark .recovery-code {
    background: #2a2a2a;
    color: #0f0;
}

.recovery-codes {
    margin-top: 1rem;
}

.qr-section, .recovery-section, .verify-section {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #ddd;
}

body.dark .qr-section,
body.dark .recovery-section,
body.dark .verify-section {
    border-bottom-color: #444;
}

@media (max-width: 480px) {
    .codes-container {
        grid-template-columns: 1fr;
    }
}

