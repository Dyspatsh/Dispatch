# Database
# Format: postgresql://username:password@localhost/database_name
DATABASE_URL=postgresql://dispatch:your_password_here@localhost/dispatch

# Security - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this

# File Storage - Path where encrypted files are stored
UPLOAD_DIR=/path/to/dispatch/uploads

# HTTPS Certificates - Paths to your SSL certificate files
SSL_KEYFILE=/path/to/your/private.key
SSL_CERTFILE=/path/to/your/certificate.pem

# Server Configuration
HOST=127.0.0.1
PORT=8443

# Tor Onion Address - Your actual .onion address from /var/lib/tor/dispatch/hostname
ONION_ADDRESS=your-onion-address.onion
